# Copy this file to .env and fill in real keys. Never commit the real .env file.

# console.groq.com -> API Keys. Used to run Llama 3.3 for the diagnoser (Rep 2 & 3).
GROQ_API_KEY=

# app.tavily.com -> API Keys (free tier, 1000 credits, no card). Used by the search_web tool.
TAVILY_API_KEY=

# console.anthropic.com -> API Keys. Used only for the Rep 1 trace capture (a second, independent provider).
ANTHROPIC_API_KEY=
